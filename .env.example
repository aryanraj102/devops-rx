OPENROUTER_API_KEY=your_openrouter_key_here
SECRET_KEY=change-this-to-a-random-string-in-production
# Google OAuth — create a "Web application" OAuth client at
# https://console.cloud.google.com/apis/credentials and add
# <your-app-url>/auth/google/callback as an authorized redirect URI.
# Leave blank to disable the Google sign-in button.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override — must be a valid OpenRouter model ID
# (defaults to deepseek/deepseek-chat)
DEEPSEEK_MODEL=
# PostgreSQL connection string, e.g. postgresql://user@localhost:5432/mywebsite
# Leave blank to store users in data/users.json instead (no transaction history).
DATABASE_URL=
# Recorded as source_app on users/transaction_history rows (default: ops-sight)
APP_NAME=
SLACK_WEBHOOK_URL=
JIRA_URL=
JIRA_EMAIL=
JIRA_TOKEN=
JIRA_PROJECT=OPS
# Optional: seed test users on startup. JSON array of user objects.
# Example: [{"first_name":"Admin","last_name":"User","email":"admin@example.com","password":"yourpassword"}]
# Leave blank in production.
SEED_USERS=
